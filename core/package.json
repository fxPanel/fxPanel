{
    "name": "fxpanel-core",
    "version": "0.2.2",
    "description": "The core package is the backend of fxPanel and handles running fxserver and the web server and every other internal backend stuff.",
    "type": "module",
    "scripts": {
        "build": "cd ../ && npx tsx scripts/build/publish.ts",
        "dev": "cd ../ && npx tsx scripts/build/dev.ts",
        "dev:watch-only": "cd ../ && npx tsx scripts/build/dev-watch-only.ts",
        "test": "vitest",
        "typecheck": "tsc -p tsconfig.json --noEmit | node ../scripts/typecheck-formatter.js",
        "typecheck:full": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "lint:count": "eslint . -f ../scripts/lint-formatter.js",
        "lint:fix": "eslint . --fix",
        "license:report": "npx license-report > ../.reports/license/core.html"
    },
    "keywords": [],
    "author": "SomeAussieGaymer",
    "license": "MIT",
    "dependencies": {
        "@koa/cors": "^5.0.0",
        "@koa/router": "^15.4.0",
        "boxen": "^8.0.1",
        "bytes": "^3.1.2",
        "cookies": "^0.9.1",
        "cookie": "^1.1.1",
        "d3-array": "^3.2.4",
        "dateformat": "^5.0.3",
        "ejs": "^5.0.2",
        "error-stack-parser": "^2.1.4",
        "esbuild": "0.28.0",
        "fuse.js": "^7.3.0",
        "got": "^15.0.3",
        "is-localhost-ip": "^3.0.1",
        "jose": "^6.2.2",
        "js-yaml": "^4.1.1",
        "keygrip": "^1.1.0",
        "koa": "^3.2.0",
        "koa-bodyparser": "^4.4.1",
        "koa-ratelimit": "^6.0.0",
        "lodash": "^4.17.21",
        "lowdb": "^7.0.1",
        "mnemonist": "^0.40.3",
        "mysql2": "^3.22.2",
        "nanoid": "^5.1.9",
        "nanoid-dictionary": "^5.0.0",
        "node-polyglot": "^2.6.0",
        "node-stream-zip": "^1.15.0",
        "open": "11.0.0",
        "otpauth": "^9.5.1",
        "rotating-file-stream": "^3.2.9",
        "slash": "^5.1.0",
        "slug": "^11.0.1",
        "socket.io": "^4.8.3",
        "source-map-support": "^0.5.21",
        "stream-json": "^2.1.0",
        "string-argv": "^0.3.2",
