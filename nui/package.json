{
    "name": "fxpanel-nui",
    "version": "0.2.2",
    "description": "The NUI package contains all the in-game interface (menu and warn page) of fxPanel.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "vitest run --passWithNoTests",
        "test:ui": "vitest --ui",
        "test:run": "vitest run --passWithNoTests",
        "build": "vite build --mode production",
        "dev": "vite build --watch --mode development",
        "browser": "vite dev --port 40121 --strictPort --mode devNuiBrowser",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "license:report": "npx license-report > ../.reports/license/nui.html"
    },
    "keywords": [],
    "author": "SomeAussieGaymer",
    "license": "MIT",
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource-variable/inter": "^5.2.8",
        "@mui/icons-material": "^6.5.0",
        "@mui/material": "^6.5.0",
        "@mui/system": "^6.5.0",
        "jotai": "^2.19.1",
        "nanoid": "5.1.9",
        "notistack": "^3.0.2",
        "react-polyglot": "^0.7.2"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node-polyglot": "^2.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.0",
        "@vitest/ui": "^4.1.5",
        "jsdom": "^29.0.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    }
}
